# ============================================================
# Dynamo WSR Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Supabase ────────────────────────────────────────────────
# Find these in Supabase Dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Edge Functions Environment ─────────────────────
# Set these in Supabase Dashboard → Settings → Edge Functions → Secrets
# (These are NOT used by the SvelteKit app directly)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...  (for embeddings)
# LATTICE_API_KEY=lat_...
# LATTICE_API_URL=https://api.latticehq.com/v1

# ─── Azure AD (Entra ID) OAuth ───────────────────────────────
# Configure in Supabase Dashboard → Authentication → Providers → Azure
# These are set in Supabase, NOT in this .env file:
# AZURE_CLIENT_ID=your-azure-app-client-id
# AZURE_CLIENT_SECRET=your-azure-app-client-secret
# AZURE_TENANT_ID=your-azure-tenant-id

# ─── App Config ──────────────────────────────────────────────
# Port for the Node.js server (EC2 deployment)
PORT=3000
NODE_ENV=production
